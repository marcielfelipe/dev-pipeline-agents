# Anthropic - used by ADK LlmAgents and Claude Code CLI
ANTHROPIC_API_KEY=sk-ant-...

# Linear - get your API key at: Linear > Settings > API > Personal API Keys
LINEAR_API_KEY=lin_api_...
# Get team ID: open your team in Linear > Cmd+K > "Copy model UUID"
LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Project paths
DESIGNS_DIR=./designs
PROJECT_DIR=./src
